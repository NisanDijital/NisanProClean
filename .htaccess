RewriteEngine On

# Force canonical URL in a single hop: https + non-www
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.nisankoltukyikama\.com$ [NC]
RewriteRule ^ https://nisankoltukyikama.com%{REQUEST_URI} [L,R=301]

# Redirect common legacy paths discovered by crawlers
RedirectMatch 301 ^/public_html/index\.html$ /
RedirectMatch 301 ^/index\.html$ /
RedirectMatch 301 ^/public_html/(.*)$ /$1
RedirectMatch 301 ^/(public_html/)+(.+)$ /$2
RedirectMatch 301 ^/nisanproclean/?$ /
RedirectMatch 301 ^/nisanproclean/(.*)$ /
RedirectMatch 301 ^/home/?$ /

# Serve a custom 404 page instead of a blank host error
ErrorDocument 404 /404.html

# Ensure charset header for text responses
AddDefaultCharset UTF-8

<IfModule mod_headers.c>
  Header always set X-Powered-By "NisanProClean"
  Header always set X-UA-Compatible "IE=edge"
  Header always set X-Site-Name "nisankoltukyikama.com"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-origin"
  Header always set Content-Language "tr"
</IfModule>
