RewriteEngine On

# Force canonical URL in a single hop: https + non-www
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.nisankoltukyikama\.com$ [NC]
RewriteRule ^ https://nisankoltukyikama.com%{REQUEST_URI} [L,R=301]

# Redirect common legacy paths discovered by crawlers
RedirectMatch 301 ^/public_html/index\.html$ /
RedirectMatch 301 ^/index\.html$ /
RedirectMatch 301 ^/public_html/(.*)$ /$1
RedirectMatch 301 ^/(public_html/)+(.+)$ /$2
RedirectMatch 301 ^/nisanproclean/?$ /
RedirectMatch 301 ^/nisanproclean/(.*)$ /
RedirectMatch 301 ^/home/?$ /

# Serve a custom 404 page instead of a blank host error
ErrorDocument 404 /404.html

# Ensure charset header for text responses
AddDefaultCharset UTF-8
AddType application/manifest+json .webmanifest

<IfModule mod_headers.c>
  Header always set X-Powered-By "NisanProClean"
  Header always set X-UA-Compatible "IE=edge"
  Header always set X-Site-Name "nisankoltukyikama.com"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-origin"
  Header always set Content-Language "tr"

  <FilesMatch "\.(js|css|woff2|woff|ttf|otf|svg|jpg|jpeg|png|webp|avif|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "^(sw\.js|manifest\.webmanifest)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 5 minutes"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/manifest+json "access plus 0 seconds"
</IfModule>
