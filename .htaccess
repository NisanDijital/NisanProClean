RewriteEngine On

# Force canonical URL in a single hop: https + non-www
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.nisankoltukyikama\.com$ [NC]
RewriteRule ^ https://nisankoltukyikama.com%{REQUEST_URI} [L,R=301]

# Ensure charset header for text responses
AddDefaultCharset UTF-8

<IfModule mod_headers.c>
  Header always set X-Powered-By "NisanProClean"
  Header always set X-UA-Compatible "IE=edge"
  Header always set X-Site-Name "nisankoltukyikama.com"
</IfModule>
